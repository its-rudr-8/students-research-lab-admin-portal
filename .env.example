# ============================================================
# Students Research Lab — Admin Portal Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Backend API base URL (no trailing slash needed — handled in code)
# Local dev:  http://localhost:8000
# Production: https://your-backend-domain.com
VITE_BACKEND_URL=http://localhost:8000

# Google Sheets Integration
# API Key: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_SHEETS_API_KEY=your_google_api_key_here

# Sheet ID from URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
VITE_GOOGLE_SHEET_ID=your_google_sheet_id_here
